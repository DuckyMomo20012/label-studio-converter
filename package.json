{
  "name": "label-studio-converter",
  "type": "module",
  "version": "1.6.1",
  "description": "Convert between Label Studio OCR format and PPOCRLabelv2 format",
  "author": "DuckyMomo20012",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DuckyMomo20012/label-studio-converter.git"
  },
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.mts",
  "bin": {
    "label-studio-converter": "./dist/cli.js",
    "__label-studio-converter_bash_complete": "./dist/bash-complete.js"
  },
  "files": [
    "dist",
    "liturgical"
  ],
  "scripts": {
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "postinstall": "npx @stricli/auto-complete@latest install label-studio-converter --bash __label-studio-converter_bash_complete"
  },
  "dependencies": {
    "@stricli/auto-complete": "1.3.0",
    "@stricli/core": "1.3.0",
    "chalk": "5.6.2",
    "dotenv": "17.4.2",
    "es-toolkit": "1.49.0",
    "image-size": "2.0.2",
    "sharp": "0.35.3",
    "type-fest": "5.8.0",
    "winston": "3.19.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@arethetypeswrong/cli": "0.18.5",
    "@babel/core": "8.0.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@types/node": "26.1.1",
    "@vitest/eslint-plugin": "1.6.23",
    "@vitest/ui": "4.1.10",
    "eslint": "10.7.0",
    "eslint-plugin-format": "2.0.1",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "tsdown": "0.22.8",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
