{
  "name": "label-studio-converter",
  "version": "1.5.0",
  "author": "DuckyMomo20012",
  "description": "Convert between Label Studio OCR format and PPOCRLabelv2 format",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DuckyMomo20012/label-studio-converter.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "liturgical"
  ],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "label-studio-converter": "./dist/cli.js",
    "__label-studio-converter_bash_complete": "./dist/bash-complete.js"
  },
  "scripts": {
    "prepare": "husky",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ test/",
    "lint:fix": "eslint src/ test/ --fix",
    "build": "tsc && tsup",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
    "check-all": "pnpm run type-check && pnpm run lint && pnpm run test:run",
    "prepublish": "pnpm run build && pnpm run check-exports && pnpm run check-all",
    "postinstall": "npx @stricli/auto-complete@latest install label-studio-converter --bash __label-studio-converter_bash_complete"
  },
  "dependencies": {
    "@stricli/auto-complete": "1.2.7",
    "@stricli/core": "1.2.7",
    "@turf/turf": "7.3.5",
    "chalk": "5.6.2",
    "es-toolkit": "1.47.0",
    "image-size": "2.0.2",
    "sharp": "0.34.5",
    "type-fest": "5.7.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.3",
    "@babel/core": "7.29.7",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@types/node": "25.9.2",
    "@typescript-eslint/eslint-plugin": "8.61.0",
    "@typescript-eslint/parser": "8.61.0",
    "@vitest/eslint-plugin": "1.6.19",
    "@vitest/ui": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
